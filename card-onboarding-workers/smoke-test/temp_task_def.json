{
    "containerDefinitions": [
        {
            "name": "onboard-service",
            "image": "956304645902.dkr.ecr.ap-southeast-1.amazonaws.com/onboard-service:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp",
                    "name": "onboard-service-8080-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "AWS_REGION",
                    "value": "ap-southeast-1"
                },
                {
                    "name": "PORT",
                    "value": "8080"
                },
                {
                    "name": "DYNAMODB_TABLE_DETAILS",
                    "value": "onboard-service-account-details"
                },
                {
                    "name": "ACCOUNT_SERVICE_URL",
                    "value": "http://account-service.local:8082"
                },
                {
                    "name": "ENV",
                    "value": "DEV"
                },
                {
                    "name": "DYNAMODB_TABLE_STATUS",
                    "value": "onboard-service-request-status"
                },
                {
                    "name": "CUSTOMER_SERVICE_URL",
                    "value": "http://customer-service.local:8081"
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/onboard-service",
                    "awslogs-create-group": "true",
                    "awslogs-region": "ap-southeast-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "onboard-service",
    "taskRoleArn": "arn:aws:iam::956304645902:role/AmazonDynamoDBFullAccess",
    "executionRoleArn": "arn:aws:iam::956304645902:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}